# Dependențe — se instalează în volume-uri din container
/vendor
/node_modules

# Git și IDE
.git
.gitignore
.gitattributes
.idea
.vscode
*.md

# Laravel runtime (nu sunt necesare în contextul de build al imaginii)
/storage/*.key
/storage/logs
/storage/framework/cache
/storage/framework/sessions
/storage/framework/views
/bootstrap/cache/*.php

# Teste și artefacte
/tests
.phpunit.result.cache
.php_cs.cache
coverage
*.log

# Env local (nu copia secrete în imagine; bind mount le aduce oricum la run)
.env
.env.*
!.env.example

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Frontend build (regenerat în container dacă e nevoie)
/public/hot
/public/build
